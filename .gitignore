# ==================== 1. IDE 配置（PyCharm/VSCode） ====================
# 忽略 PyCharm 配置目录（核心）
.idea/
# 忽略 VSCode 配置（如果用 VSCode 可保留，不用则删除）
.vscode/
*.code-workspace

# ==================== 2. Python 项目通用忽略项 ====================
# 忽略 Python 编译产物（字节码文件）
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 忽略虚拟环境目录（不管你用 venv/conda 都适用）
venv/
env/
.venv/
conda-env/

# 忽略 pip/conda 依赖文件（可选：如需共享依赖，可删除这行，改用 requirements.txt）
# pip-freeze.txt
# environment.yml

# ==================== 3. 系统/临时文件 ====================
# Windows 临时文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac 系统隐藏文件
.DS_Store

# 日志/临时文件
*.log
*.tmp
*.swp
*.swo
*.bak

# ==================== 4. 项目专属忽略项（按需修改） ====================
# 忽略数据文件（比如大的 CSV/JSON/模型文件，根据你的项目调整）
data/
model/
*.bin
*.pth
*.h5

# 忽略敏感配置文件（比如包含密码的 config.py）
# config/local_config.py
